# Copy to .env and fill in. .env is git-ignored.
ANTHROPIC_API_KEY=sk-ant-...

# Model used to analyze findings + write the report.
# claude-sonnet-5 is the cost/quality sweet spot; claude-opus-4-8 is the
# higher-capability (and pricier) option if you want deeper analysis.
RECONSCRIBE_MODEL=claude-sonnet-5

# Politeness: seconds to wait between outbound requests to a target.
RECONSCRIBE_REQUEST_DELAY=0.5
